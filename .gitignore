# ----------------------------------------------------------------------------
#  Build output
# ----------------------------------------------------------------------------
build/
build-*/
out/
cmake-build-*/        # CLion default build dirs

# CMake internals (if ever generated outside build/)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
_deps/

# ----------------------------------------------------------------------------
#  Compiled artifacts
# ----------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.dylib

# ...but Wavefront model files under assets/ are SOURCE, not compiled objects —
# `*.obj` above would otherwise swallow them (Step 9's assets/torus.obj).
!assets/*.obj
*.dll
*.exe

# Step 16: the Damaged Helmet glTF (~3.6 MB) is DOWNLOADED at configure time
# (see CMakeLists.txt), not committed. Other .glb models (sphere.glb) stay tracked.
assets/DamagedHelmet.glb

# ----------------------------------------------------------------------------
#  Editor / IDE
# ----------------------------------------------------------------------------
# Track the *shared* VS Code config (clangd, build tasks, debug) so a clone gets
# a working editor setup, but keep ignoring the per-user files VS Code drops in
# .vscode/ (workspace state, per-machine overrides, etc.).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
.cache/             # clangd
*.swp
*~

# ----------------------------------------------------------------------------
#  Test / tooling artifacts
# ----------------------------------------------------------------------------
.playwright-mcp/     # browser-based doc verification output

# ----------------------------------------------------------------------------
#  macOS
# ----------------------------------------------------------------------------
.DS_Store
